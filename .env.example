# REQUIRED: Dashboard password
VAULT_PASSWORD=changeme

# REQUIRED: Public URL where the hub is accessible (used for enrollment links)
# Must NOT have a trailing slash
# Example: https://vault.example.com
VAULT_EXTERNAL_URL=

# Optional: Host port mapping (default: 8080)
VAULT_PORT=8080

# Optional: GitHub repo for binary downloads in enrollment scripts
# Example: driversti/ssh-vault
VAULT_GITHUB_REPO=

# Optional: GitHub release tag for binary downloads
# Example: v1.0.0 (defaults to "latest")
VAULT_RELEASE_TAG=
